## SECRET_KEY: строка для подписи сессий Flask (и защиты от подделки данных).
## Варианты: любая длинная случайная строка (например, результат генерации token_hex).
# Вариант:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=174afe9c231a4bfc89713b29174edaaab74c1260bd5e96a85d9592b39db3defe

## FLASK_ENV: окружение приложения. Варианты: development | production | testing.
## Влияет на DEBUG и поведение обработки ошибок.
FLASK_ENV=development

DATABASE_PATH=data/FISH.db
